# Production Environment Configuration
# Copy this file to .env and fill in your values

# Server Configuration
PORT=4000
NODE_ENV=production
CORS_ORIGIN=https://your-production-domain.com

# Authentication - Generate a secure secret:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
AUTH_SECRET=your-secure-random-string-here

# PostgreSQL Database
# Option 1: Individual connection parameters
PGHOST=your-db-host.example.com
PGPORT=5432
PGUSER=your-db-username
PGPASSWORD=your-secure-password
PGDATABASE=security_gate_management

# Option 2: Connection URL (uncomment and use instead of PG* vars above)
# DATABASE_URL=postgresql://user:password@host:5432/database

# For Coolify/Railway/Render deployments, use DATABASE_URL
